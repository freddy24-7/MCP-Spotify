# ============================================================
# Spotify MCP Server – Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# ============================================================

# --- Spotify Application Credentials ---
# Obtain these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# --- OAuth Redirect URI ---
# Must match one of the Redirect URIs registered in your Spotify app settings.
# For local development the default below works out of the box.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback


# --- Optional: Log level ---
# Accepts: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
