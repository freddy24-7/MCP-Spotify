{
  "$schema": "https://raw.githubusercontent.com/jlowin/fastmcp/main/src/fastmcp/server/fastmcp.schema.json",
  "name": "spotify-mcp-server",
  "description": "Spotify playback and playlist controls via the Model Context Protocol.",
  "version": "0.1.0",

  "transport": "stdio",

  "server": {
    "module": "src.server",
    "object": "mcp"
  },

  "env": {
    "SPOTIFY_CLIENT_ID": "${SPOTIFY_CLIENT_ID}",
    "SPOTIFY_CLIENT_SECRET": "${SPOTIFY_CLIENT_SECRET}",
    "SPOTIFY_REDIRECT_URI": "${SPOTIFY_REDIRECT_URI}"
  }
}
